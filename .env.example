# ============================================================
# .env.example — copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...
COHERE_API_KEY=...

# --- Vector Store ---
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=...
PINECONE_INDEX_NAME=llm_sysrev_corpus

# --- Bibliographic Database APIs ---
PUBMED_API_KEY=...          # NCBI E-utilities key (optional but higher rate limit)
SEMANTIC_SCHOLAR_API_KEY=...

# --- Local Data Paths (update to match your machine) ---
DATA_PRIVATE_DIR=/path/to/data_private        # Local only — never committed
RAW_PDF_DIR=${DATA_PRIVATE_DIR}/raw
DEIDENTIFIED_DIR=${DATA_PRIVATE_DIR}/deidentified
EXTRACTED_TEXT_DIR=${DATA_PRIVATE_DIR}/extracted_text
METHOD_OUTPUTS_DIR=${DATA_PRIVATE_DIR}/method_outputs

# --- Project Paths ---
PROJECT_ROOT=/path/to/llm_systematic_review
DATA_DIR=${PROJECT_ROOT}/data
CORPUS_DIR=${DATA_DIR}/corpus
PROCESSED_DIR=${DATA_DIR}/processed

# --- Embedding Model ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# --- LLM Settings ---
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# --- Agentic RAG Settings ---
AGENT_MAX_ITERATIONS=10
AGENT_MAX_SUBQUERIES=5

# --- Logging ---
LOG_LEVEL=INFO
